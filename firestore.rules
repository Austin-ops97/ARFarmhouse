rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /** Signed-in family members (private beta). Property seed data may be empty. */
    function isFamilyMember() {
      return isSignedIn();
    }

    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    function priorCommentCount() {
      return resource.data.commentCount is int ? resource.data.commentCount : 0;
    }

    /** App admins (`admin`) and legacy family owners (`owner`). */
    function isAppAdmin() {
      return isSignedIn()
        && userDoc().role in ['admin', 'owner'];
    }

    function isBookingOwner() {
      return isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    function isCalendarEventOwner() {
      return isSignedIn() && resource.data.requestedBy == request.auth.uid;
    }

    function validBookingStatus(status) {
      return status in ['pending', 'pending_conflict', 'approved', 'denied', 'cancelled'];
    }

    function validBookingType(type) {
      return type in ['booking', 'event'];
    }

    function validOptionalPropertyId() {
      return !('propertyId' in request.resource.data)
        || (request.resource.data.propertyId is string
          && request.resource.data.propertyId.size() > 0
          && request.resource.data.propertyId.size() <= 64);
    }

    function validPostBody() {
      return request.resource.data.body is string
        && request.resource.data.body.size() <= 12000;
    }

    function validPostTitle() {
      return !('title' in request.resource.data)
        || (request.resource.data.title == null)
        || (request.resource.data.title is string
          && request.resource.data.title.size() <= 200);
    }

    function isPollPostData() {
      return request.resource.data.contentType == 'poll'
        && request.resource.data.poll is map
        && request.resource.data.poll.question is string
        && request.resource.data.poll.question.size() > 0
        && request.resource.data.poll.question.size() <= 200
        && request.resource.data.poll.options is list
        && request.resource.data.poll.options.size() >= 2
        && request.resource.data.poll.options.size() <= 6
        && request.resource.data.poll.allowMultiple is bool
        && (!('expiresAt' in request.resource.data.poll)
          || request.resource.data.poll.expiresAt == null
          || request.resource.data.poll.expiresAt is timestamp);
    }

    function validFeedPostCreate() {
      return validPostBody()
        && validPostTitle()
        && (
          !('contentType' in request.resource.data)
          || request.resource.data.contentType == 'standard'
          || (request.resource.data.contentType == 'poll' && isPollPostData())
        );
    }

    /** Post author or platform admin/owner — used for cascade deletes of engagement subcollections. */
    function canCascadeDeletePostEngagement(postId) {
      let post = get(/databases/$(database)/documents/posts/$(postId)).data;
      return isSignedIn()
        && post.authorId is string
        && (post.authorId == request.auth.uid || isAppAdmin());
    }

    function canDeleteFeedPost() {
      return isSignedIn()
        && resource.data.authorId is string
        && (resource.data.authorId == request.auth.uid || isAppAdmin());
    }

    function validSignupRedemption() {
      return request.resource.data.signupRedemptionId is string
        && request.resource.data.signupRedemptionId.size() > 0
        && exists(/databases/$(database)/documents/signupRedemptions/$(request.resource.data.signupRedemptionId))
        && get(/databases/$(database)/documents/signupRedemptions/$(request.resource.data.signupRedemptionId)).data.used == false
        && get(/databases/$(database)/documents/signupRedemptions/$(request.resource.data.signupRedemptionId)).data.expiresAt > request.time
        && get(/databases/$(database)/documents/signupRedemptions/$(request.resource.data.signupRedemptionId)).data.emailLower
          == request.auth.token.email.lower();
    }

    match /signupRedemptions/{redemptionId} {
      allow read, write: if false;
    }

    match /_security/{docId} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId)
        && validSignupRedemption()
        && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isSelf(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
        && (
          !('notificationsEnabled' in request.resource.data)
          || request.resource.data.notificationsEnabled is bool
        )
        && (
          !('notificationPreferences' in request.resource.data)
          || request.resource.data.notificationPreferences is map
        );
      allow delete: if false;

      match /savedPosts/{postId} {
        allow read: if isSelf(userId);
        allow create, update, delete: if isSelf(userId)
          && (!('postId' in request.resource.data) || request.resource.data.postId == postId);
      }

      match /notifications/{notificationId} {
        allow read: if isSelf(userId);
        /** Inbox writes are server-only (Cloud Functions Admin SDK). */
        allow create: if false;
        allow update: if isSelf(userId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readAt']);
        allow delete: if isSelf(userId);
      }

      match /notificationTokens/{tokenId} {
        allow read: if isSelf(userId);
        allow create: if isSelf(userId)
          && request.resource.data.token is string
          && request.resource.data.token.size() > 0
          && request.resource.data.token.size() <= 4096
          && request.resource.data.platform is string
          && request.resource.data.browser is string;
        allow update: if isSelf(userId)
          && request.resource.data.token == resource.data.token
          && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['updatedAt', 'platform', 'browser']);
        allow delete: if isSelf(userId);
      }
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorDisplayName is string
        && validFeedPostCreate()
        && validOptionalPropertyId();

      allow update: if isSignedIn() && (
        (resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == request.auth.uid)
        || (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['commentCount', 'updatedAt'])
          && (
            request.resource.data.commentCount == priorCommentCount() + 1
            || request.resource.data.commentCount == priorCommentCount() - 1
          )
        )
        || (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['reactionCounts', 'updatedAt'])
          && request.resource.data.reactionCounts is map
        )
        || (
          resource.data.contentType == 'poll'
          && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['poll', 'updatedAt'])
          && request.resource.data.poll is map
        )
      );

      allow delete: if canDeleteFeedPost();

      match /reactions/{uid} {
        allow read: if isSignedIn();
        allow create, update: if isSelf(uid)
          && request.resource.data.emoji is string
          && request.resource.data.emoji.size() > 0
          && request.resource.data.emoji.size() <= 16;
        allow delete: if isSelf(uid) || canCascadeDeletePostEngagement(postId);
      }

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (
          resource.data.authorId == request.auth.uid
          || canCascadeDeletePostEngagement(postId)
        );
      }

      match /pollVotes/{uid} {
        allow read: if isSignedIn();
        allow create, update: if isSelf(uid)
          && request.resource.data.optionIds is list
          && request.resource.data.optionIds.size() <= 6;
        allow delete: if isSelf(uid) || canCascadeDeletePostEngagement(postId);
      }
    }

    match /houseTasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200;
      allow update: if isSignedIn()
        && resource.data.createdBy == request.resource.data.createdBy
        && !request.resource.data.diff(resource.data).changedKeys().hasAny(['createdBy']);
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    function validChecklistPercent(field) {
      return request.resource.data[field] is int
        && request.resource.data[field] >= 0
        && request.resource.data[field] <= 100;
    }

    function validChecklistSubmission() {
      return request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.submittedByName is string
        && request.resource.data.submittedByName.size() > 0
        && request.resource.data.submittedByName.size() <= 120
        && validChecklistPercent('propaneLevel')
        && validChecklistPercent('deerFeederLevel')
        && validChecklistPercent('fishFeederLevel')
        && request.resource.data.doorsLocked is bool
        && request.resource.data.houseLightsOff is bool
        && request.resource.data.electronicsUnplugged is bool
        && request.resource.data.wellBreakerOff is bool
        && request.resource.data.windmillValveClosed is bool
        && request.resource.data.trashcanLidsClosed is bool
        && request.resource.data.trashOut is bool
        && request.resource.data.gasCansFilled is bool
        && request.resource.data.imageUrls is map;
    }

    match /checklists/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && docId == 'current'
        && validChecklistSubmission();
      allow update: if isSignedIn()
        && docId == 'current'
        && validChecklistSubmission();
      allow delete: if isAppAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdByName is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 160
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 2000
        && validBookingType(request.resource.data.type)
        && validBookingStatus(request.resource.data.status)
        && request.resource.data.status in ['pending', 'pending_conflict']
        && request.resource.data.startDate is timestamp
        && request.resource.data.endDate is timestamp
        && request.resource.data.endDate >= request.resource.data.startDate
        && validOptionalPropertyId();
      allow update: if isSignedIn() && (
        (isBookingOwner()
          && unchanged('createdBy')
          && request.resource.data.status in ['pending', 'pending_conflict', 'cancelled'])
        || isAppAdmin()
      );
      allow delete: if isSignedIn() && isAppAdmin();
    }

    match /blackoutDates/{blackoutId} {
      allow read: if isSignedIn();
      allow create: if isAppAdmin()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 160
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500
        && request.resource.data.startDate is timestamp
        && request.resource.data.endDate is timestamp
        && request.resource.data.endDate >= request.resource.data.startDate
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAppAdmin()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 160
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500
        && request.resource.data.startDate is timestamp
        && request.resource.data.endDate is timestamp
        && request.resource.data.endDate >= request.resource.data.startDate;
      allow delete: if isAppAdmin();
    }

    match /calendarEvents/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.requestedByName is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 160
        && request.resource.data.startDay is int
        && request.resource.data.startDay >= 1
        && request.resource.data.startDay <= 31
        && request.resource.data.year is int
        && request.resource.data.monthIndex is int
        && request.resource.data.monthIndex >= 0
        && request.resource.data.monthIndex <= 11
        && request.resource.data.bookingRequestId is string
        && request.resource.data.bookingRequestId.size() > 0
        && (
          !('endDay' in request.resource.data)
          || (
            request.resource.data.endDay is int
            && request.resource.data.endDay >= request.resource.data.startDay
            && request.resource.data.endDay <= 31
          )
        );
      allow update: if isSignedIn() && (
        (isCalendarEventOwner()
          && unchanged('requestedBy')
          && unchanged('bookingRequestId')
          && unchanged('year')
          && unchanged('monthIndex'))
        || isAppAdmin()
      );
      allow delete: if isSignedIn() && (isCalendarEventOwner() || isAppAdmin());
    }

    match /albumMedia/{mediaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorDisplayName is string
        && request.resource.data.storageUrl is string
        && request.resource.data.storagePath is string
        && request.resource.data.caption is string
        && request.resource.data.caption.size() <= 500
        && request.resource.data.albumKey is string
        && request.resource.data.albumKey.size() <= 40;
      allow update: if isSignedIn()
        && resource.data.authorId == request.auth.uid
        && unchanged('authorId')
        && unchanged('storagePath')
        && (
          unchanged('storageUrl')
          || (
            resource.data.processingStatus == 'processing'
            && request.resource.data.processingStatus == 'processing'
            && request.resource.data.storageUrl is string
          )
        );
      allow delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || isAppAdmin());
    }

    match /bookingRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.requestedByName is string
        && request.resource.data.startDay is int
        && request.resource.data.startDay >= 1
        && request.resource.data.year is int
        && request.resource.data.monthIndex is int
        && request.resource.data.monthIndex >= 0
        && request.resource.data.monthIndex <= 11
        && request.resource.data.status == 'pending'
        && request.resource.data.calendarEventId is string
        && request.resource.data.calendarEventId.size() > 0
        && (
          !('endDay' in request.resource.data)
          || (
            request.resource.data.endDay is int
            && request.resource.data.endDay >= request.resource.data.startDay
          )
        );
      allow update, delete: if false;
    }

    match /propertyStatus/{cardId} {
      allow read: if isFamilyMember();
      allow create, update, delete: if isFamilyMember();
    }

    match /propertyMapPins/{pinId} {
      allow read: if isFamilyMember();
      allow create, update, delete: if isFamilyMember();
    }

    match /propertyMapTrails/{trailId} {
      allow read: if isFamilyMember();
      allow create, update, delete: if isFamilyMember();
    }

    match /propertyResources/{resourceId} {
      allow read: if isFamilyMember();
      allow create, update, delete: if isFamilyMember();
    }

    match /propertyInventory/{itemId} {
      allow read: if isFamilyMember();
      allow create, update, delete: if isFamilyMember();
    }

    match /systemSettings/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAppAdmin();
      allow delete: if false;
    }

    match /sharedGroceryItems/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.kind in ["meal", "grocery"]
        && request.resource.data.label is string
        && request.resource.data.label.size() > 0
        && request.resource.data.label.size() <= 200;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.createdByUid == request.auth.uid;
    }
  }
}
