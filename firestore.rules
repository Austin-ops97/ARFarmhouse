rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    /** Signed-in family members (private beta). Property seed data may be empty. */
    function isFamilyMember() {
      return isSignedIn();
    }

    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    function priorCommentCount() {
      return resource.data.commentCount is int ? resource.data.commentCount : 0;
    }

    /** Family owners may moderate album uploads (delete any albumMedia row). */
    function familyOwner() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == 'member');
      allow update: if isSelf(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
      allow delete: if false;

      match /savedPosts/{postId} {
        allow read: if isSelf(userId);
        allow create, update, delete: if isSelf(userId)
          && (!('postId' in request.resource.data) || request.resource.data.postId == postId);
      }

      match /notifications/{notificationId} {
        allow read: if isSelf(userId);
        allow create: if isSignedIn()
          && request.resource.data.actorId == request.auth.uid;
        allow update: if isSelf(userId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readAt']);
        allow delete: if isSelf(userId);
      }
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorDisplayName is string
        && request.resource.data.body is string;

      allow update: if isSignedIn() && (
        (resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == request.auth.uid)
        || (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['commentCount', 'updatedAt'])
          && (
            request.resource.data.commentCount == priorCommentCount() + 1
            || request.resource.data.commentCount == priorCommentCount() - 1
          )
        )
        || (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['reactionCounts', 'updatedAt'])
          && request.resource.data.reactionCounts is map
        )
      );

      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      match /reactions/{uid} {
        allow read: if isSignedIn();
        allow create, update: if isSelf(uid)
          && request.resource.data.emoji is string
          && request.resource.data.emoji.size() > 0
          && request.resource.data.emoji.size() <= 16;
        allow delete: if isSelf(uid);
      }

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    match /houseTasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200;
      allow update: if isSignedIn()
        && resource.data.createdBy == request.resource.data.createdBy
        && !request.resource.data.diff(resource.data).changedKeys().hasAny(['createdBy']);
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /calendarEvents/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.requestedByName is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 160
        && request.resource.data.startDay is int
        && request.resource.data.startDay >= 1
        && request.resource.data.startDay <= 31
        && request.resource.data.year is int
        && request.resource.data.monthIndex is int
        && request.resource.data.monthIndex >= 0
        && request.resource.data.monthIndex <= 11
        && request.resource.data.bookingRequestId is string
        && request.resource.data.bookingRequestId.size() > 0
        && (
          !('endDay' in request.resource.data)
          || (
            request.resource.data.endDay is int
            && request.resource.data.endDay >= request.resource.data.startDay
            && request.resource.data.endDay <= 31
          )
        );
      allow update: if isSignedIn()
        && resource.data.requestedBy == request.auth.uid
        && unchanged('requestedBy')
        && unchanged('bookingRequestId')
        && unchanged('year')
        && unchanged('monthIndex');
      allow delete: if isSignedIn() && resource.data.requestedBy == request.auth.uid;
    }

    match /albumMedia/{mediaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorDisplayName is string
        && request.resource.data.storageUrl is string
        && request.resource.data.storagePath is string
        && request.resource.data.caption is string
        && request.resource.data.caption.size() <= 500
        && request.resource.data.albumKey is string
        && request.resource.data.albumKey.size() <= 40;
      allow update: if isSignedIn()
        && resource.data.authorId == request.auth.uid
        && unchanged('authorId')
        && unchanged('storagePath')
        && (
          unchanged('storageUrl')
          || (
            resource.data.processingStatus == 'processing'
            && request.resource.data.processingStatus == 'processing'
            && request.resource.data.storageUrl is string
          )
        );
      allow delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || familyOwner());
    }

    match /bookingRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.requestedByName is string
        && request.resource.data.startDay is int
        && request.resource.data.startDay >= 1
        && request.resource.data.year is int
        && request.resource.data.monthIndex is int
        && request.resource.data.monthIndex >= 0
        && request.resource.data.monthIndex <= 11
        && request.resource.data.status == 'pending'
        && request.resource.data.calendarEventId is string
        && request.resource.data.calendarEventId.size() > 0
        && (
          !('endDay' in request.resource.data)
          || (
            request.resource.data.endDay is int
            && request.resource.data.endDay >= request.resource.data.startDay
          )
        );
      allow update, delete: if false;
    }

    match /propertyStatus/{cardId} {
      allow read: if isFamilyMember();
      allow create, update, delete: if isFamilyMember();
    }

    match /propertyMapPins/{pinId} {
      allow read: if isFamilyMember();
      allow create, update, delete: if isFamilyMember();
    }

    match /propertyMapTrails/{trailId} {
      allow read: if isFamilyMember();
      allow create, update, delete: if isFamilyMember();
    }

    match /propertyResources/{resourceId} {
      allow read: if isFamilyMember();
      allow create, update, delete: if isFamilyMember();
    }

    match /propertyInventory/{itemId} {
      allow read: if isFamilyMember();
      allow create, update, delete: if isFamilyMember();
    }

    match /sharedGroceryItems/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.kind in ["meal", "grocery"]
        && request.resource.data.label is string
        && request.resource.data.label.size() > 0
        && request.resource.data.label.size() <= 200;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.createdByUid == request.auth.uid;
    }
  }
}
