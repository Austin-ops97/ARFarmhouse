# Firebase (client) — copy to `.env.local` and fill from the Firebase console
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Storage bucket string exactly as shown under Firebase Console → Storage (often `<project-id>.firebasestorage.app`).
# If you still have the legacy default `<project-id>.appspot.com` here, it is rewritten automatically when it matches PROJECT_ID above.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Auth — set to true to show "Create account" on /login (required for new family onboarding)
NEXT_PUBLIC_REGISTRATION_OPEN=true
# Optional allowlists when REGISTRATION_OPEN=true (comma-separated)
NEXT_PUBLIC_SIGNUP_ALLOWLIST_EMAILS=
NEXT_PUBLIC_SIGNUP_ALLOWLIST_DOMAINS=

# Invite codes are validated server-side only (Firebase Functions secrets INVITE_PEPPER + INVITE_CODE_HASHES).
# Optional: connect to the Functions emulator in local dev
# NEXT_PUBLIC_FIREBASE_FUNCTIONS_EMULATOR=true

# Public site URL for share links and deep links (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
