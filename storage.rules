rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    /** Mirrors Firestore `users/{uid}.role` — owners may delete any album object (moderation). */
    function familyOwner() {
      return signedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    function albumUploader(mediaId) {
      return firestore.get(/databases/(default)/documents/albumMedia/$(mediaId)).data.authorId;
    }

    match /albums/{mediaId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && fileName.matches('^[0-9]+-[0-9]+\\.(jpg|jpeg|png|webp|gif)$');
      allow delete: if signedIn()
        && firestore.exists(/databases/(default)/documents/albumMedia/$(mediaId))
        && (
          albumUploader(mediaId) == request.auth.uid
          || familyOwner()
        );
    }

    match /posts/{postId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && fileName.matches('^[a-zA-Z0-9._-]+$');
    }

    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && fileName.matches('^profile\\.(jpg|jpeg|png|webp|gif)$');
    }

    match /users/{userId}/profile/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && fileName.matches('^avatar\\.(jpg|jpeg|png|webp|gif)$');
    }

    match /users/{userId}/family/{memberId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && fileName.matches('^photo\\.(jpg|jpeg|png|webp|gif)$');
    }

    match /users/{userId}/pets/{petId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && fileName.matches('^photo\\.(jpg|jpeg|png|webp|gif)$');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
