rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAppAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner'];
    }

    function validImageContentType() {
      return request.resource.contentType is string
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/octet-stream'
          || request.resource.contentType == ''
        )
        && !request.resource.contentType.matches('image/svg\\+xml');
    }

    function notDangerousUpload() {
      return !request.resource.name.matches('.*\\.(exe|bat|cmd|sh|msi|apk|dmg|js|html)(\\.|$).*');
    }

    /*
      TEMPORARILY generous upload cap because:
      - Firebase Functions now handle compression
      - browser should not aggressively compress
      - iPhone images can exceed 50MB+
    */
    function validUploadSize() {
      return request.resource.size > 0
        && request.resource.size <= 150 * 1024 * 1024;
    }

    /*
    ==================================================
    RAW FEED UPLOADS
    ==================================================
    */

    match /uploads/raw/{uid}/posts/{postId}/{allPaths=**} {

      allow read: if signedIn();

      allow write: if isOwner(uid)
        && validUploadSize()
        && validImageContentType()
        && notDangerousUpload();

      allow delete: if isOwner(uid) || isAppAdmin();
    }

    /*
    ==================================================
    RAW ALBUM UPLOADS
    ==================================================
    */

    match /uploads/raw/{uid}/albumMedia/{mediaId}/{allPaths=**} {

      allow read: if signedIn();

      allow write: if isOwner(uid)
        && validUploadSize()
        && validImageContentType()
        && notDangerousUpload();

      allow delete: if isOwner(uid);
    }

    /*
    ==================================================
    PROFILE PHOTOS
    ==================================================
    */

    match /uploads/raw/{uid}/avatars/{allPaths=**} {

      allow read: if signedIn();

      allow write: if isOwner(uid)
        && validUploadSize()
        && validImageContentType();

      allow delete: if isOwner(uid);
    }

    /*
    ==================================================
    FAMILY MEMBER PHOTOS
    ==================================================
    */

    match /uploads/raw/{uid}/family/{allPaths=**} {

      allow read: if signedIn();

      allow write: if isOwner(uid)
        && validUploadSize()
        && validImageContentType();

      allow delete: if isOwner(uid);
    }

    /*
    ==================================================
    PET PHOTOS
    ==================================================
    */

    match /uploads/raw/{uid}/pets/{allPaths=**} {

      allow read: if signedIn();

      allow write: if isOwner(uid)
        && validUploadSize()
        && validImageContentType();

      allow delete: if isOwner(uid);
    }

    /*
    ==================================================
    CHECKLIST WALKTHROUGH PHOTOS
    ==================================================
    */

    match /checklists/{submissionId}/{fieldName}/{allPaths=**} {

      allow read: if signedIn();

      allow write: if signedIn()
        && validUploadSize()
        && validImageContentType()
        && notDangerousUpload();

      allow delete: if signedIn() && submissionId == 'current'
        || isAppAdmin();
    }

    /*
    ==================================================
    PROCESSED MEDIA
    ==================================================

    Firebase Functions generate:
    - thumbnails
    - feed variants
    - optimized images

    Admin SDK bypasses rules automatically.
    */

    match /media/processed/{allPaths=**} {

      allow read: if signedIn();

      allow write: if false;

      allow delete: if false;
    }

    /*
    ==================================================
    FALLBACK DENY
    ==================================================
    */

    match /{allPaths=**} {

      allow read, write: if false;
    }
  }
}
