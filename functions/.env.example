# Local / emulator only — production uses Firebase secrets (never commit real values).
# Generate hashes: INVITE_PEPPER='...' node functions/scripts/hash-invite-code.mjs 'your-code'
INVITE_PEPPER=
INVITE_CODE_HASHES=

# Canonical site origin for push deep links (no trailing slash). Production:
#   firebase functions:config:set site.origin="https://your-domain.vercel.app"
# or set SITE_ORIGIN in Cloud Functions environment (Firebase Console → Functions → Environment).
SITE_ORIGIN=https://arfarmhouse.com
